---
import Base from '@layouts/Base.astro';
import Hero from '@components/Hero.astro';
import AboutSection from '@components/AboutSection.astro';
import HighlightsSection from '@components/HighlightsSection.astro';
import FridayMenu from '@components/FridayMenu.astro';
import DishModal from '@components/DishModal.astro';
import SectionDivider from '@components/SectionDivider.astro';

const lang = 'eu' as const;
---

<Base lang={lang} currentPath="/">
  <Hero lang={lang} />

  <SectionDivider variant="line" />

  <AboutSection lang={lang} />

  <FridayMenu lang={lang} />

  <SectionDivider variant="brush" />

  <HighlightsSection lang={lang} />

  <DishModal lang={lang} />
</Base>
