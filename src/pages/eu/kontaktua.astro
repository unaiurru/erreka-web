---
import Base from '@layouts/Base.astro';
import { useTranslations } from '@i18n/index';
import { restaurant } from '@content/restaurant';
import MapEmbed from '@components/MapEmbed.astro';

const lang = 'eu' as const;
const t = useTranslations(lang);
---

<Base lang={lang} currentPath="/contacto" pageTitle="Kontaktua">
  <section class="contact-page container">
    <div class="section-label">{t('contact_page.label')}</div>
    <h1 class="section-title">{t('contact_page.title')}</h1>

    <div class="contact-grid">
      <div class="contact-info">
        <div class="info-block">
          <h3>{t('contact_page.where')}</h3>
          <p>
            {t('contact_page.address_line1')}<br>
            {t('contact_page.address_line2')}
          </p>
        </div>

        <div class="info-block">
          <h3>{t('contact_page.contact')}</h3>
          <p>
            <a href={`tel:${restaurant.phone}`}>{restaurant.phoneDisplay}</a><br>
            <a href={`https://wa.me/${restaurant.whatsapp}`} target="_blank" rel="noopener">
              {t('contact_page.whatsapp')}
            </a>
          </p>
        </div>

        <div class="info-block">
          <h3>{t('contact_page.hours')}</h3>
          <ul class="hours">
            {restaurant.hours.map(h => (
              <li class:list={[{ closed: h.closed }]}>
                <span>{t(`contact_page.days.${h.day}`)}</span>
                <span>{h.closed ? t('contact_page.closed') : `${h.open} — ${h.close}`}</span>
              </li>
            ))}
          </ul>
        </div>

        <div class="info-block">
          <h3>{t('contact_page.social')}</h3>
          <div class="social-links">
            <a href={restaurant.social.instagram} target="_blank" rel="noopener" aria-label="Instagram">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="2" y="2" width="20" height="20" rx="5"/>
                <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
                <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
              </svg>
            </a>
          </div>
        </div>
      </div>

      <div class="contact-map">
        <MapEmbed lang={lang} title="Erreka Meet Point — Mungia" />
      </div>
    </div>
  </section>
</Base>

<style>
  .contact-page { padding: 4rem var(--gutter) 6rem; }
  .contact-grid {
    display: grid; grid-template-columns: 1fr 1.2fr;
    gap: 4rem; align-items: start; margin-top: 2rem;
  }
  .info-block { margin-bottom: 2.5rem; }
  .info-block h3 {
    font-family: var(--font-display); font-size: 1.25rem;
    letter-spacing: 0.15em; color: var(--copper); margin-bottom: 0.75rem;
  }
  .info-block p, .info-block a {
    font-family: var(--font-serif); font-size: 1.05rem;
    color: var(--cream-soft); font-weight: 300; line-height: 1.7;
  }
  .info-block a:hover { color: var(--copper-bright); }

  .hours {
    list-style: none; font-family: var(--font-serif);
    color: var(--cream-soft); font-weight: 300;
  }
  .hours li {
    display: flex; justify-content: space-between;
    padding: 0.45rem 0; border-bottom: 1px solid var(--line); max-width: 360px;
  }
  .hours li.closed { opacity: 0.5; }

  .social-links { display: flex; gap: 1rem; }
  .social-links a {
    width: 44px; height: 44px;
    border: 1px solid var(--cream);
    display: flex; align-items: center; justify-content: center;
    border-radius: 50%; transition: all 0.2s;
  }
  .social-links a:hover { background: var(--copper); border-color: var(--copper); color: var(--bg); }

  .contact-map {
    border-radius: 4px; overflow: hidden; min-height: 480px;
    border: 1px solid var(--line);
    position: sticky; top: calc(var(--nav-height) + 1rem);
  }
  .contact-map iframe {
    width: 100%; height: 100%; min-height: 480px;
    border: 0;
  }

  @media (max-width: 900px) {
    .contact-grid { grid-template-columns: 1fr; gap: 2rem; }
    .contact-map { position: static; min-height: 360px; }
    .contact-map iframe { min-height: 360px; }
  }
</style>
