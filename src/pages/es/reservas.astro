---
import Base from '@layouts/Base.astro';
import { useTranslations, useArray } from '@i18n/index';
import { restaurant } from '@content/restaurant';

const lang = 'es' as const;
const t = useTranslations(lang);
const arr = useArray(lang);
const policyItems = arr('reserve_page.policy.items');
---

<Base
  lang={lang}
  currentPath="/reservas"
  pageTitle="Reservar mesa"
  pageDescription="Reserva online en Erreka Meet Point. Mungia, Bizkaia."
>

  <section class="reserve-page container-narrow">
    <div class="reserve-header">
      <div class="section-label centered">{t('reserve_page.label')}</div>
      <h1 class="section-title">{t('reserve_page.title')}</h1>
      <p class="reserve-intro">
        {t('reserve_page.intro')}
        <a href={`tel:${restaurant.phone}`} class="phone-link">
          {restaurant.phoneDisplay}
        </a>.
      </p>
    </div>

    <form
      class="reserve-widget"
      id="reserveForm"
      novalidate
      autocomplete="off"
    >
      <span class="reserve-widget-note">{t('reserve_page.widget_note')}</span>

      <!--
        Anti-bot: honeypot + token temporal.
        · El campo `website` es invisible para humanos pero visible para bots.
          Si se rellena, descartamos el envío.
        · El input `_t` guarda el timestamp de carga; si la diferencia con el
          envío es < 1500 ms, asumimos bot.
        · Cuando se conecte el widget real de TheFork, lo más limpio es añadir
          además Cloudflare Turnstile (gratis, sin cookies, sin banner adicional).
          Ver README sección "Seguridad y anti-bot".
      -->
      <div class="hp-field" aria-hidden="true">
        <label>Website (no rellenar)</label>
        <input type="text" name="website" tabindex="-1" autocomplete="off">
      </div>
      <input type="hidden" name="_t" value="">

      <div class="reserve-form">
        <div>
          <label for="rf-people">{t('reserve_page.form.people')}</label>
          <select id="rf-people" name="people" required>
            {[2, 3, 4, 5, 6, 7, 8].map(n => (
              <option>{n} {t('reserve_page.form.people_unit')}</option>
            ))}
          </select>
        </div>
        <div>
          <label for="rf-date">{t('reserve_page.form.date')}</label>
          <input id="rf-date" name="date" type="date" required>
        </div>
        <div>
          <label for="rf-time">{t('reserve_page.form.time')}</label>
          <select id="rf-time" name="time" required>
            <option>13:30</option><option>14:00</option><option>14:30</option><option>15:00</option>
            <option>20:30</option><option>21:00</option><option>21:30</option><option>22:00</option>
          </select>
        </div>
      </div>
      <button class="btn btn-primary reserve-submit" type="submit" id="reserveBtn">
        {t('reserve_page.form.submit')}
      </button>
    </form>

    <div class="reserve-policy">
      <h2>{t('reserve_page.policy.title')}</h2>
      <ul>
        {policyItems.map(item => <li>{item}</li>)}
      </ul>
    </div>
  </section>

</Base>

<style>
  .reserve-page {
    padding: 5rem var(--gutter) 5rem;
    text-align: center;
  }
  .reserve-header {
    margin-bottom: 3rem;
  }
  .reserve-intro {
    font-family: var(--font-serif);
    font-size: 1.15rem;
    color: var(--cream-soft);
    font-weight: 300;
    max-width: 540px;
    margin: 0 auto 2rem;
  }
  .phone-link {
    color: var(--copper-bright);
    border-bottom: 1px solid var(--copper-bright);
  }

  .reserve-widget {
    background: var(--bg-card);
    border: 1px solid var(--line);
    padding: 3rem 2rem;
    border-radius: 4px;
    position: relative;
    margin-bottom: 4rem;
  }
  .reserve-widget-note {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    font-family: var(--font-body);
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--copper);
    opacity: 0.6;
    background: var(--bg);
    padding: 0.3rem 0.6rem;
    border-radius: 2px;
  }
  .reserve-form {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 1rem;
    margin-bottom: 1.5rem;
  }
  .reserve-form label {
    display: block;
    font-family: var(--font-body);
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--copper);
    margin-bottom: 0.5rem;
    text-align: left;
  }
  .reserve-form select, .reserve-form input {
    width: 100%;
    padding: 0.85rem 1rem;
    background: var(--bg);
    border: 1px solid var(--line);
    color: var(--cream);
    font-family: var(--font-body);
    font-size: 0.95rem;
    border-radius: 2px;
  }
  .reserve-form select:focus, .reserve-form input:focus {
    outline: none;
    border-color: var(--copper);
  }
  .reserve-submit { width: 100%; }

  /* Honeypot: invisible para humanos, visible para bots automáticos */
  .hp-field {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    overflow: hidden;
    opacity: 0;
    pointer-events: none;
  }

  .reserve-policy {
    text-align: left;
    border-top: 1px solid var(--line);
    padding-top: 3rem;
  }
  .reserve-policy h2 {
    font-family: var(--font-display);
    font-size: 1.4rem;
    letter-spacing: 0.15em;
    color: var(--copper);
    margin-bottom: 1.5rem;
  }
  .reserve-policy ul {
    list-style: none;
    font-family: var(--font-serif);
    font-size: 1rem;
    line-height: 1.7;
    color: var(--cream-soft);
    font-weight: 300;
  }
  .reserve-policy li {
    padding: 0.5rem 0 0.5rem 1.5rem;
    position: relative;
  }
  .reserve-policy li::before {
    content: "—";
    color: var(--copper);
    position: absolute;
    left: 0;
  }
</style>

<script>
  /**
   * Validación cliente del formulario de reservas (demo).
   * En la web real, este handler debería redirigir al widget de TheFork
   * con los parámetros pre-rellenados, e idealmente comprobar Cloudflare
   * Turnstile en el lado del servidor antes de aceptar la reserva.
   */
  const form = document.getElementById('reserveForm') as HTMLFormElement | null;
  const tField = form?.querySelector<HTMLInputElement>('input[name="_t"]');
  if (tField) tField.value = String(Date.now());

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    if (!form) return;

    const data = new FormData(form);
    const honeypot = (data.get('website') || '').toString();
    const t0 = parseInt(((data.get('_t') || '0').toString()), 10);
    const elapsed = Date.now() - (Number.isFinite(t0) ? t0 : 0);

    // Bot probable: campo honeypot relleno o envío en menos de 1.5s
    if (honeypot.trim().length > 0 || elapsed < 1500) {
      // Aceptamos en silencio para no informar al bot.
      console.warn('reservas: envío descartado por heurística anti-bot');
      return;
    }

    // Resto de comprobaciones nativas
    if (!form.reportValidity()) return;

    alert('Demo · En la web real esto abriría TheFork con la reserva pre-rellenada.');
  });
</script>
