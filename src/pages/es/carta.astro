---
import Base from '@layouts/Base.astro';
import MenuPage from '@components/MenuPage.astro';
import DishModal from '@components/DishModal.astro';

const lang = 'es' as const;
---

<Base
  lang={lang}
  currentPath="/carta"
  pageTitle="Carta"
  pageDescription="Carta completa de Erreka Meet Point: entrantes, burgers, novedades y postres."
>
  <MenuPage lang={lang} />
  <DishModal lang={lang} />
</Base>
