---
import Base from '@layouts/Base.astro';
import DishCard from '@components/DishCard.astro';
import DishModal from '@components/DishModal.astro';
import { useTranslations } from '@i18n/index';
import { starters, burgers, novelties, desserts } from '@content/menu';

const lang = 'es' as const;
const t = useTranslations(lang);

const sections = [
  { id: 'starters', title: t('menu_page.tabs.starters'), dishes: starters },
  { id: 'burgers', title: t('menu_page.tabs.burgers'), dishes: burgers, note: t('menu_page.burgers_note') },
  { id: 'novelties', title: t('menu_page.tabs.novelties'), dishes: novelties, note: t('menu_page.novelties_note') },
  { id: 'desserts', title: t('menu_page.tabs.desserts'), dishes: desserts },
];
---

<Base
  lang={lang}
  currentPath="/carta"
  pageTitle="Carta"
  pageDescription="Carta completa de Erreka Meet Point: entrantes, burgers, novedades y postres."
>

  <section class="page-header container">
    <div class="section-label">{t('menu_page.label')}</div>
    <h1 class="section-title">
      {t('menu_page.title_line1')}<br>
      {t('menu_page.title_line2')}
    </h1>
    <p class="page-intro">{t('menu_page.intro')}</p>

    <p class="menu-hint">{t('menu_page.click_hint')}</p>

    <nav class="menu-anchors">
      {sections.map(s => (
        <a href={`#${s.id}`}>{s.title}</a>
      ))}
    </nav>
  </section>

  {sections.map(section => (
    <section class="menu-section container" id={section.id}>
      <h2 class="menu-section-title">{section.title}</h2>
      <div class="menu-grid">
        {section.dishes.map(dish => <DishCard dish={dish} lang={lang} />)}
      </div>
      {section.note && <div class="menu-note">{section.note}</div>}
    </section>
  ))}

  <DishModal lang={lang} />

</Base>

<style>
  .page-header {
    padding: 4rem var(--gutter) 2rem;
  }
  .page-intro {
    font-family: var(--font-serif);
    font-size: 1.15rem;
    color: var(--cream-soft);
    max-width: 640px;
    line-height: 1.7;
    margin-bottom: 1rem;
    font-weight: 300;
  }
  .menu-anchors {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    border-top: 1px solid var(--line);
    padding-top: 1.5rem;
  }
  .menu-anchors a {
    padding: 0.6rem 1.2rem;
    font-family: var(--font-display);
    font-size: 1rem;
    letter-spacing: 0.15em;
    color: var(--cream-soft);
    border: 1px solid var(--line);
    border-radius: 2px;
    transition: all 0.2s;
  }
  .menu-anchors a:hover {
    color: var(--copper);
    border-color: var(--copper);
  }

  .menu-section {
    padding: 4rem var(--gutter);
    scroll-margin-top: calc(var(--nav-height) + 1rem);
  }
  .menu-section-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3rem);
    letter-spacing: 0.05em;
    color: var(--copper);
    margin-bottom: 2.5rem;
    border-bottom: 1px solid var(--line);
    padding-bottom: 1rem;
  }
  .menu-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem 4rem;
  }
  .menu-hint {
    margin: 0 0 2rem;
    font-family: var(--font-body);
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--cream-mute);
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }
  .menu-hint::before {
    content: "";
    width: 6px;
    height: 6px;
    background: var(--copper);
    border-radius: 50%;
    flex-shrink: 0;
  }
  .menu-note {
    margin-top: 3rem;
    padding: 1.25rem 1.5rem;
    background: var(--bg-card);
    border-left: 3px solid var(--copper);
    font-family: var(--font-serif);
    font-style: italic;
    color: var(--cream-soft);
    font-size: 0.95rem;
  }

  @media (max-width: 768px) {
    .menu-grid { grid-template-columns: 1fr; gap: 1.5rem; }
    .page-header { padding: 2rem 1.25rem 1rem; }
    .menu-section { padding: 3rem 1.25rem; }
  }
</style>
