---
import Base from '@layouts/Base.astro';
import LegalPage from '@components/LegalPage.astro';
import { useTranslations } from '@i18n/index';
import { avisoLegal, legalLastUpdate } from '@content/legal';

const lang = 'es' as const;
const t = useTranslations(lang);
const data = avisoLegal.es;
---

<Base
  lang={lang}
  currentPath="/aviso-legal"
  pageTitle={data.title}
  pageDescription="Aviso legal de Erreka Meet Point. Datos identificativos, condiciones de uso y propiedad intelectual."
>
  <LegalPage
    label={t('legal.label.info')}
    title={data.title}
    sections={data.sections}
    lastUpdate={legalLastUpdate}
    lastUpdateLabel={t('legal.last_update')}
  />
</Base>
