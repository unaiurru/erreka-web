---
import { useTranslations, type Lang, localizedPath } from '@i18n/index';

interface Props {
  lang: Lang;
  /** Path actual sin prefijo de idioma, para enlaces del switcher */
  currentPath: string;
}

const { lang, currentPath } = Astro.props;
const t = useTranslations(lang);

const links = [
  { href: '/', key: 'nav.home' },
  { href: '/carta', key: 'nav.menu' },
  { href: '/sobre-nosotros', key: 'nav.about' },
  { href: '/reservas', key: 'nav.reserve' },
  { href: '/contacto', key: 'nav.contact' },
];

// Mapas de rutas: las URL son distintas en cada idioma para que sea SEO-friendly
const routeMap: Record<Lang, Record<string, string>> = {
  es: { '/': '/', '/carta': '/carta', '/sobre-nosotros': '/sobre-nosotros', '/reservas': '/reservas', '/contacto': '/contacto' },
  eu: { '/': '/', '/carta': '/karta', '/sobre-nosotros': '/gu-nor-garen', '/reservas': '/erreserbak', '/contacto': '/kontaktua' },
};

function urlFor(targetLang: Lang, basePath: string) {
  const mapped = routeMap[targetLang][basePath] ?? basePath;
  return localizedPath(targetLang, mapped);
}
---

<nav class="nav">
  <a href={urlFor(lang, '/')} class="nav-logo">
    ERREKA <span>·</span> MEET POINT
  </a>

  <ul class="nav-links">
    {links.map(link => (
      <li>
        <a
          href={urlFor(lang, link.href)}
          class:list={[{ active: currentPath === link.href }]}
        >
          {t(link.key)}
        </a>
      </li>
    ))}
  </ul>

  <div class="nav-right">
    <div class="lang-switch">
      <a href={urlFor('es', currentPath)} class:list={['lang-btn', { active: lang === 'es' }]}>ES</a>
      <a href={urlFor('eu', currentPath)} class:list={['lang-btn', { active: lang === 'eu' }]}>EU</a>
    </div>
    <a href={urlFor(lang, '/reservas')} class="nav-cta">
      {t('nav.reserve')}
    </a>
    <button class="nav-burger" aria-label="Menu" id="navBurger">
      <span></span><span></span><span></span>
    </button>
  </div>
</nav>

<!-- Menú móvil -->
<div class="mobile-menu" id="mobileMenu">
  <ul>
    {links.map(link => (
      <li><a href={urlFor(lang, link.href)}>{t(link.key)}</a></li>
    ))}
    <li class="mobile-lang">
      <a href={urlFor('es', currentPath)} class:list={[{ active: lang === 'es' }]}>Castellano</a>
      <span>·</span>
      <a href={urlFor('eu', currentPath)} class:list={[{ active: lang === 'eu' }]}>Euskara</a>
    </li>
  </ul>
</div>

<style>
  .nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    height: var(--nav-height);
    padding: 0 var(--gutter);
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: rgba(22, 19, 16, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--line);
  }
  .nav-logo {
    font-family: var(--font-display);
    font-size: 1.5rem;
    letter-spacing: 0.1em;
    color: var(--cream);
  }
  .nav-logo span { color: var(--copper); }

  .nav-links {
    display: flex;
    gap: 2rem;
    list-style: none;
    font-size: 0.85rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .nav-links a {
    color: var(--cream-soft);
    transition: color 0.2s ease;
    position: relative;
    padding: 0.5rem 0;
  }
  .nav-links a:hover { color: var(--copper-bright); }
  .nav-links a.active {
    color: var(--copper);
  }
  .nav-links a.active::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 0; right: 0;
    height: 1px;
    background: var(--copper);
  }

  .nav-right {
    display: flex;
    gap: 0.75rem;
    align-items: center;
  }

  .lang-switch {
    display: flex;
    border: 1px solid var(--line);
    border-radius: 2px;
    overflow: hidden;
  }
  .lang-btn {
    padding: 0.45rem 0.7rem;
    font-family: var(--font-body);
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    font-weight: 500;
    color: var(--cream-soft);
    transition: all 0.2s ease;
  }
  .lang-btn:hover { color: var(--cream); }
  .lang-btn.active {
    background: var(--copper);
    color: var(--bg);
  }

  .nav-cta {
    background: var(--copper);
    color: var(--bg);
    padding: 0.6rem 1.2rem;
    font-weight: 500;
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    border-radius: 2px;
    transition: background 0.2s ease;
  }
  .nav-cta:hover { background: var(--copper-bright); }

  /* Burger móvil */
  .nav-burger {
    display: none;
    background: none;
    border: none;
    width: 32px;
    height: 32px;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    cursor: pointer;
  }
  .nav-burger span {
    display: block;
    height: 2px;
    background: var(--cream);
    transition: all 0.25s;
  }
  .nav-burger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .nav-burger.open span:nth-child(2) { opacity: 0; }
  .nav-burger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  .mobile-menu {
    position: fixed;
    top: var(--nav-height);
    left: 0; right: 0;
    background: var(--bg);
    border-bottom: 1px solid var(--line);
    transform: translateY(-100%);
    transition: transform 0.3s ease;
    z-index: 99;
  }
  .mobile-menu.open { transform: translateY(0); }
  .mobile-menu ul {
    list-style: none;
    padding: 2rem var(--gutter);
  }
  .mobile-menu li {
    padding: 0.85rem 0;
    border-bottom: 1px solid var(--line);
  }
  .mobile-menu li:last-child { border: none; }
  .mobile-menu a {
    font-family: var(--font-display);
    font-size: 1.25rem;
    letter-spacing: 0.15em;
    color: var(--cream);
    text-transform: uppercase;
  }
  .mobile-menu a:hover, .mobile-menu a.active { color: var(--copper); }
  .mobile-lang {
    display: flex !important;
    gap: 0.75rem;
    align-items: center;
    padding-top: 1.5rem !important;
  }
  .mobile-lang span { color: var(--cream-mute); }
  .mobile-lang a {
    font-family: var(--font-body);
    font-size: 0.85rem;
    letter-spacing: 0.1em;
  }

  @media (max-width: 900px) {
    .nav-links { display: none; }
    .nav-cta { display: none; }
    .nav-burger { display: flex; }
  }
</style>

<script>
  const burger = document.getElementById('navBurger');
  const menu = document.getElementById('mobileMenu');
  burger?.addEventListener('click', () => {
    burger.classList.toggle('open');
    menu?.classList.toggle('open');
  });
  // Cerrar al hacer click en un enlace del menú móvil
  menu?.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', () => {
      burger?.classList.remove('open');
      menu?.classList.remove('open');
    });
  });
</script>
