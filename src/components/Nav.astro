---
import { useTranslations, type Lang, localizedPath } from '@i18n/index';
import OpenStatus from '@components/OpenStatus.astro';
import Icon from '@components/Icon.astro';

interface Props {
  lang: Lang;
  /** Path actual sin prefijo de idioma, para enlaces del switcher */
  currentPath: string;
}

const { lang, currentPath } = Astro.props;
const t = useTranslations(lang);

const links = [
  { href: '/', key: 'nav.home' },
  { href: '/carta', key: 'nav.menu' },
  { href: '/sobre-nosotros', key: 'nav.about' },
  { href: '/reservas', key: 'nav.reserve' },
  { href: '/contacto', key: 'nav.contact' },
];

// Mapas de rutas: las URL son distintas en cada idioma para que sea SEO-friendly
const routeMap: Record<Lang, Record<string, string>> = {
  es: { '/': '/', '/carta': '/carta', '/sobre-nosotros': '/sobre-nosotros', '/reservas': '/reservas', '/contacto': '/contacto' },
  eu: { '/': '/', '/carta': '/karta', '/sobre-nosotros': '/gu-nor-garen', '/reservas': '/erreserbak', '/contacto': '/kontaktua' },
};

function urlFor(targetLang: Lang, basePath: string) {
  const mapped = routeMap[targetLang][basePath] ?? basePath;
  return localizedPath(targetLang, mapped);
}
---

<nav class="nav" id="siteNav" data-scrolled="false">
  <a href={urlFor(lang, '/')} class="nav-logo" aria-label="Erreka Meet Point">
    <span class="nav-logo-main">ERREKA</span><span class="nav-logo-sep">·</span><span class="nav-logo-sub">MEET POINT</span>
  </a>

  <ul class="nav-links">
    {links.map(link => (
      <li>
        <a
          href={urlFor(lang, link.href)}
          class:list={[{ active: currentPath === link.href }]}
        >
          <span class="nav-link-text">{t(link.key)}</span>
        </a>
      </li>
    ))}
  </ul>

  <div class="nav-right">
    <OpenStatus lang={lang} size="sm" />

    <div class="lang-switch">
      <a href={urlFor('es', currentPath)} class:list={['lang-btn', { active: lang === 'es' }]}>ES</a>
      <a href={urlFor('eu', currentPath)} class:list={['lang-btn', { active: lang === 'eu' }]}>EU</a>
    </div>
    <a href={urlFor(lang, '/reservas')} class="nav-cta">
      {t('nav.reserve')}
    </a>
    <button class="nav-burger" aria-label="Menu" id="navBurger" aria-expanded="false" aria-controls="mobileMenu">
      <span></span><span></span><span></span>
    </button>
  </div>
</nav>

<!-- Menú móvil -->
<div class="mobile-menu" id="mobileMenu" aria-hidden="true">
  <ul>
    {links.map(link => (
      <li><a href={urlFor(lang, link.href)}>{t(link.key)}</a></li>
    ))}
    <li class="mobile-status">
      <OpenStatus lang={lang} size="md" />
    </li>
    <li class="mobile-lang">
      <a href={urlFor('es', currentPath)} class:list={[{ active: lang === 'es' }]}>Castellano</a>
      <span>·</span>
      <a href={urlFor('eu', currentPath)} class:list={[{ active: lang === 'eu' }]}>Euskara</a>
    </li>
  </ul>
</div>

<style>
  .nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    height: var(--nav-height);
    padding: 0 var(--gutter);
    display: flex;
    justify-content: space-between;
    align-items: center;
    /* Anti-overflow: nav fija a viewport y nunca empuja el ancho del documento */
    max-width: 100%;
    gap: 0.5rem;
    background: rgba(22, 19, 16, 0.7);
    backdrop-filter: blur(14px) saturate(140%);
    -webkit-backdrop-filter: blur(14px) saturate(140%);
    border-bottom: 1px solid transparent;
    transition: background 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
  }
  .nav[data-scrolled="true"] {
    background: rgba(13, 11, 9, 0.92);
    border-bottom-color: var(--line);
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.35);
  }

  .nav-logo {
    font-family: var(--font-display);
    /* Tamaño fluido — encoge en pantallas estrechas para no empujar el layout */
    font-size: clamp(1.05rem, 4.2vw, 1.5rem);
    letter-spacing: 0.08em;
    color: var(--cream);
    transition: color 0.2s ease;
    /* Permite que el flex child se encoja por debajo de su intrínseco */
    min-width: 0;
    flex-shrink: 1;
    white-space: nowrap;
    display: inline-flex;
    align-items: baseline;
    gap: 0.4em;
  }
  .nav-logo:hover { color: var(--copper-bright); }
  .nav-logo .nav-logo-sep { color: var(--copper); }
  .nav-logo .nav-logo-sub { color: var(--cream); }

  .nav-links {
    display: flex;
    gap: 2rem;
    list-style: none;
    font-size: 0.85rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .nav-links a {
    color: var(--cream-soft);
    transition: color 0.2s ease;
    position: relative;
    padding: 0.5rem 0;
    display: inline-block;
  }
  .nav-links a:hover { color: var(--copper-bright); }
  .nav-links a.active { color: var(--copper); }

  /* Subrayado copper animado: scale-x left-to-right en hover, stay si .active */
  .nav-links a::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 0; right: 0;
    height: 1px;
    background: var(--copper);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.3s var(--ease-out-soft);
  }
  .nav-links a:hover::after,
  .nav-links a.active::after,
  .nav-links a:focus-visible::after {
    transform: scaleX(1);
  }

  .nav-right {
    display: flex;
    gap: 0.75rem;
    align-items: center;
    /* Anti-overflow: nunca empujar al logo */
    min-width: 0;
    flex-shrink: 0;
  }

  /* Switcher idioma — pill compacto bien encuadrado.
     Antes el fondo del botón activo se desbordaba ligeramente del borde
     redondeado por la combinación border + border-radius + overflow:hidden
     en flex. Ahora alineamos altura, paddings y line-height para que el
     fondo quede perfectamente clipado dentro del borde. */
  .lang-switch {
    display: inline-flex;
    align-items: stretch;
    border: 1px solid var(--line);
    border-radius: 4px;
    overflow: hidden;
    height: 30px;
    line-height: 1;
    flex-shrink: 0;
  }
  .lang-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 36px;
    padding: 0 0.6rem;
    font-family: var(--font-body);
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    font-weight: 500;
    color: var(--cream-soft);
    background: transparent;
    transition: background 0.2s ease, color 0.2s ease;
  }
  .lang-btn + .lang-btn {
    border-left: 1px solid var(--line);
  }
  .lang-btn:hover { color: var(--cream); }
  .lang-btn.active {
    background: var(--copper);
    color: var(--bg);
  }

  .nav-cta {
    background: var(--copper);
    color: var(--bg);
    padding: 0.6rem 1.2rem;
    font-weight: 500;
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    border-radius: 2px;
    transition: background 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
  }
  .nav-cta:hover {
    background: var(--copper-bright);
    transform: translateY(-1px);
    box-shadow: 0 8px 18px -6px var(--copper-glow);
  }

  /* Burger móvil */
  .nav-burger {
    display: none;
    background: none;
    border: none;
    width: 32px;
    height: 32px;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    cursor: pointer;
  }
  .nav-burger span {
    display: block;
    height: 2px;
    background: var(--cream);
    transition: all 0.25s;
  }
  .nav-burger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .nav-burger.open span:nth-child(2) { opacity: 0; }
  .nav-burger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  .mobile-menu {
    position: fixed;
    top: var(--nav-height);
    left: 0; right: 0;
    background: var(--bg);
    border-bottom: 1px solid var(--line);
    transform: translateY(-100%);
    transition: transform 0.3s ease;
    z-index: 99;
    visibility: hidden;
  }
  .mobile-menu.open {
    transform: translateY(0);
    visibility: visible;
  }
  .mobile-menu ul {
    list-style: none;
    padding: 2rem var(--gutter);
  }
  .mobile-menu li {
    padding: 0.85rem 0;
    border-bottom: 1px solid var(--line);
  }
  .mobile-menu li:last-child { border: none; }
  .mobile-menu a {
    font-family: var(--font-display);
    font-size: 1.25rem;
    letter-spacing: 0.15em;
    color: var(--cream);
    text-transform: uppercase;
  }
  .mobile-menu a:hover, .mobile-menu a.active { color: var(--copper); }
  .mobile-status {
    display: flex;
    justify-content: flex-start;
    padding-top: 1.25rem !important;
  }
  .mobile-lang {
    display: flex !important;
    gap: 0.75rem;
    align-items: center;
    padding-top: 1.5rem !important;
  }
  .mobile-lang span { color: var(--cream-mute); }
  .mobile-lang a {
    font-family: var(--font-body);
    font-size: 0.85rem;
    letter-spacing: 0.1em;
  }

  /* Ocultar el pill "Abierto/Cerrado" de la nav en pantallas medianas y
     móviles. Se usa `:global(...)` porque el componente OpenStatus tiene
     su propio scope CSS de Astro y el selector con scope cruzado no
     matchearía. La info sigue presente en el menú móvil al abrirlo. */
  @media (max-width: 1100px) {
    .nav-right > :global(.open-status) { display: none; }
  }

  @media (max-width: 900px) {
    .nav-links { display: none; }
    .nav-cta { display: none; }
    .nav-burger { display: flex; }
  }

  /* Móviles muy estrechos: ocultamos "MEET POINT" para que la nav no empuje
     y se vea limpia. "ERREKA · " se mantiene como marca principal. */
  @media (max-width: 420px) {
    .nav-logo .nav-logo-sub { display: none; }
    .nav-logo .nav-logo-sep { display: none; }
    .nav { gap: 0.4rem; }
    .nav-right { gap: 0.5rem; }
  }
</style>

<script>
  // Burger toggle
  function initNav() {
    const burger = document.getElementById('navBurger');
    const menu = document.getElementById('mobileMenu');
    const nav = document.getElementById('siteNav');

    if (burger && menu) {
      burger.addEventListener('click', () => {
        const isOpen = burger.classList.toggle('open');
        menu.classList.toggle('open', isOpen);
        burger.setAttribute('aria-expanded', String(isOpen));
        menu.setAttribute('aria-hidden', String(!isOpen));
      });
      // Cerrar al hacer click en un enlace del menú móvil
      menu.querySelectorAll('a').forEach(a => {
        a.addEventListener('click', () => {
          burger.classList.remove('open');
          menu.classList.remove('open');
          burger.setAttribute('aria-expanded', 'false');
          menu.setAttribute('aria-hidden', 'true');
        });
      });
    }

    // Scroll-shadow: pinta sombra cuando el usuario hace scroll
    if (nav) {
      const onScroll = () => {
        nav.dataset.scrolled = String(window.scrollY > 8);
      };
      onScroll();
      window.addEventListener('scroll', onScroll, { passive: true });
    }
  }

  document.addEventListener('astro:page-load', initNav);
</script>
