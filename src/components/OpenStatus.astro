---
/**
 * Pill "Abierto · cierra a las HH:MM" / "Cerrado · abre el día a HH:MM"
 *
 * Calcula el estado en cliente porque depende de la zona horaria del usuario.
 * Para SSR consistente, hacemos render inicial con el peor caso ("Comprueba
 * horarios") y luego el script lo sobrescribe.
 *
 * Acepta `lang` para textos.
 */

import { restaurant } from '@content/restaurant';
import type { Lang } from '@i18n/index';

interface Props {
  lang: Lang;
  /** Variante de tamaño visual */
  size?: 'sm' | 'md';
}

const { lang, size = 'sm' } = Astro.props;

const labels = {
  es: {
    loading: 'Comprueba horarios',
    openNow: 'Abierto',
    closesAt: 'cierra a las',
    closedNow: 'Cerrado',
    opensAt: 'abre',
    today: 'hoy',
    tomorrow: 'mañana',
    days: ['domingo', 'lunes', 'martes', 'miércoles', 'jueves', 'viernes', 'sábado'],
  },
  eu: {
    loading: 'Ordutegia begiratu',
    openNow: 'Irekita',
    closesAt: 'ixten da',
    closedNow: 'Itxita',
    opensAt: 'irekitzen da',
    today: 'gaur',
    tomorrow: 'bihar',
    days: ['igandea', 'astelehena', 'asteartea', 'asteazkena', 'osteguna', 'ostirala', 'larunbata'],
  },
}[lang];

// Pasamos los datos del restaurante al cliente como JSON (1 vez por página).
const hoursJson = JSON.stringify(restaurant.hours);
const labelsJson = JSON.stringify(labels);
---

<span
  class:list={['open-status', `open-status--${size}`]}
  data-open-status
  data-hours={hoursJson}
  data-labels={labelsJson}
>
  <i class="dot" aria-hidden="true"></i>
  <span class="text">{labels.loading}</span>
</span>

<style>
  .open-status {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-body);
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    font-weight: 500;
    color: var(--cream-mute);
    padding: 0.35rem 0.75rem;
    border: 1px solid var(--line);
    border-radius: 999px;
    background: rgba(0, 0, 0, 0.25);
    white-space: nowrap;
    transition: color 0.3s ease, border-color 0.3s ease;
  }
  .open-status--md {
    font-size: 0.8rem;
    padding: 0.5rem 1rem;
  }
  .open-status .dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--cream-mute);
    flex-shrink: 0;
    transition: background 0.3s ease, box-shadow 0.3s ease;
  }

  /* Estados pintados por el script */
  .open-status.is-open {
    color: var(--cream);
    border-color: rgba(74, 222, 128, 0.35);
  }
  .open-status.is-open .dot {
    background: var(--green-open);
    box-shadow: 0 0 0 0 rgba(74, 222, 128, 0.6);
    animation: pulse 2.4s ease-in-out infinite;
  }
  .open-status.is-closed {
    color: var(--cream-soft);
    border-color: var(--line);
  }
  .open-status.is-closed .dot {
    background: var(--red-accent);
  }

  @keyframes pulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(74, 222, 128, 0.6); }
    50%      { box-shadow: 0 0 0 6px rgba(74, 222, 128, 0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .open-status.is-open .dot { animation: none; }
  }
</style>

<script>
  type Hour = {
    day: 'mon' | 'tue' | 'wed' | 'thu' | 'fri' | 'sat' | 'sun';
    open: string;
    close: string;
    closed: boolean;
  };

  const DAY_INDEX: Record<Hour['day'], number> = {
    sun: 0, mon: 1, tue: 2, wed: 3, thu: 4, fri: 5, sat: 6,
  };

  function toMin(hhmm: string): number {
    const [h, m] = hhmm.split(':').map(Number);
    return (h || 0) * 60 + (m || 0);
  }

  function compute(hours: Hour[], labels: any) {
    const now = new Date();
    const dow = now.getDay(); // 0=Dom...6=Sab
    const nowMin = now.getHours() * 60 + now.getMinutes();

    // Buscar la entrada de hoy
    const todayEntry = hours.find(h => DAY_INDEX[h.day] === dow);

    if (todayEntry && !todayEntry.closed) {
      const openMin = toMin(todayEntry.open);
      let closeMin = toMin(todayEntry.close);
      // Cierre after-midnight: ej 00:30 → tratar como 24:30
      if (closeMin <= openMin) closeMin += 24 * 60;
      const nowAdj = nowMin < openMin ? nowMin + 24 * 60 : nowMin;
      // Estamos abiertos si nowMin entre open y close
      const isOpen = nowMin >= openMin && nowMin < closeMin
        || (nowMin < openMin && nowMin + 24 * 60 < closeMin && false); // simplificación

      if (nowMin >= openMin && (nowAdj < closeMin || nowMin < closeMin)) {
        return { open: true, label: `${labels.openNow} · ${labels.closesAt} ${todayEntry.close}` };
      }
    }

    // Cerrado — buscar el siguiente día con apertura
    for (let i = 1; i <= 7; i++) {
      const targetDow = (dow + i) % 7;
      const entry = hours.find(h => DAY_INDEX[h.day] === targetDow);
      if (entry && !entry.closed) {
        const dayName = i === 1 ? labels.tomorrow : labels.days[targetDow];
        return { open: false, label: `${labels.closedNow} · ${labels.opensAt} ${dayName} ${entry.open}` };
      }
    }
    return { open: false, label: labels.closedNow };
  }

  function paint(el: HTMLElement) {
    const hours: Hour[] = JSON.parse(el.dataset.hours || '[]');
    const labels = JSON.parse(el.dataset.labels || '{}');
    const result = compute(hours, labels);
    el.classList.remove('is-open', 'is-closed');
    el.classList.add(result.open ? 'is-open' : 'is-closed');
    const text = el.querySelector('.text');
    if (text) text.textContent = result.label;
  }

  function init() {
    document.querySelectorAll<HTMLElement>('[data-open-status]').forEach(paint);
  }

  document.addEventListener('astro:page-load', init);
</script>
