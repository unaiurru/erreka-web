---
/**
 * Sistema de iconos SVG inline.
 * Basado en Lucide (https://lucide.dev) — open source, ISC license.
 *
 * Uso: <Icon name="clock" size={20} />
 *
 * Por qué inline y no <img>: 0 requests, color heredable con currentColor,
 * y se anima con CSS sin trampas.
 */

const ICONS = {
  'clock': '<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>',
  'map-pin': '<path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"/><circle cx="12" cy="10" r="3"/>',
  'phone': '<path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>',
  'instagram': '<rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>',
  'whatsapp': '<path d="M3 21l1.65-3.8a9 9 0 1 1 3.4 2.9L3 21"/><path d="M9 10a.5.5 0 0 0 1 0V9a.5.5 0 0 0-1 0v1a5 5 0 0 0 5 5h1a.5.5 0 0 0 0-1h-1a.5.5 0 0 0 0 1"/>',
  'arrow-right': '<line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>',
  'arrow-down': '<line x1="12" y1="5" x2="12" y2="19"/><polyline points="19 12 12 19 5 12"/>',
  'star': '<polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>',
  'leaf': '<path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19.2 2.96c1 1.51.5 6.5-1.6 9.27-2 2.6-5.6 4.5-7.6 4.5-1 0-1.6-.04-2-.13"/><path d="M2 21c0-3 1.85-5.36 5.08-6"/>',
  'wheat-off': '<path d="m2 22 10-10"/><path d="m16 8-1.17 1.17"/><path d="M3.47 12.53 5 11l1.53 1.53a3.5 3.5 0 0 1 0 4.94L5 19l-1.53-1.53a3.5 3.5 0 0 1 0-4.94Z"/><path d="m8 8-.53.53a3.5 3.5 0 0 0 0 4.94L9 15l1.53-1.53c.55-.55.88-1.25.98-1.97"/><path d="M10.91 5.26c.15-.26.34-.51.56-.73L13 3l1.53 1.53a3.5 3.5 0 0 1 .28 4.62"/><path d="M20 2h2v2a4 4 0 0 1-4 4h-2V6a4 4 0 0 1 4-4Z"/><path d="M11.47 17.47 13 19l-1.53 1.53a3.5 3.5 0 0 1-4.94 0L5 19l1.53-1.53a3.5 3.5 0 0 1 4.94 0Z"/><path d="M15 13l-.53.53a3.5 3.5 0 0 0 0 4.94l.53.53"/><line x1="2" y1="2" x2="22" y2="22"/>',
  'menu': '<line x1="4" y1="6" x2="20" y2="6"/><line x1="4" y1="12" x2="20" y2="12"/><line x1="4" y1="18" x2="20" y2="18"/>',
  'x': '<line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>',
  'check': '<polyline points="20 6 9 17 4 12"/>',
  'calendar': '<rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>',
  'users': '<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>',
  'utensils': '<path d="M3 2v7c0 1.1.9 2 2 2h2v11"/><path d="M19 2v20"/><path d="M19 15h-4a2 2 0 0 1-2-2V8a4 4 0 0 1 4-4h2"/>',
  'sparkles': '<path d="M12 3l1.9 5.8a1 1 0 0 0 .6.6L20.3 11.3a.5.5 0 0 1 0 .9l-5.8 1.9a1 1 0 0 0-.6.6L12 20.3a.5.5 0 0 1-.9 0l-1.9-5.8a1 1 0 0 0-.6-.6L2.7 12.2a.5.5 0 0 1 0-.9l5.8-1.9a1 1 0 0 0 .6-.6L12 3z"/>',
  'mail': '<path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>',
} as const;

interface Props {
  name: keyof typeof ICONS;
  size?: number | string;
  strokeWidth?: number;
  class?: string;
  ariaHidden?: boolean;
  ariaLabel?: string;
}

const {
  name,
  size = 20,
  strokeWidth = 1.75,
  class: className = '',
  ariaHidden = true,
  ariaLabel,
} = Astro.props;

const path = ICONS[name];
const sizeStr = typeof size === 'number' ? `${size}px` : size;
---

<svg
  width={sizeStr}
  height={sizeStr}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width={strokeWidth}
  stroke-linecap="round"
  stroke-linejoin="round"
  class:list={['icon', `icon--${name}`, className]}
  aria-hidden={ariaHidden && !ariaLabel ? 'true' : undefined}
  aria-label={ariaLabel}
  role={ariaLabel ? 'img' : undefined}
  set:html={path}
/>

<style>
  .icon {
    display: inline-block;
    flex-shrink: 0;
    vertical-align: middle;
  }
</style>
