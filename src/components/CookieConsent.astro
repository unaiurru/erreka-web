---
/**
 * Banner de consentimiento de cookies — cumple guía AEPD julio 2023.
 *
 * Categorías:
 *  · necessary  — siempre activas.
 *  · maps       — Google Maps (página de contacto).
 *  · analytics  — placeholder.
 *  · marketing  — placeholder.
 *
 * El consentimiento se publica al resto del sitio mediante:
 *   · localStorage (clave `erreka_cookie_consent`).
 *   · CustomEvent global `cookie-consent:change`.
 *
 * Robusto frente a ViewTransitions: usa event delegation en document y
 * re-inicializa el estado en cada `astro:page-load`.
 */

import { useTranslations, type Lang, localizedPath } from '@i18n/index';

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);

const cookiesUrl = lang === 'es' ? '/es/cookies' : '/eu/cookieak';
const privacyUrl = lang === 'es' ? '/es/privacidad' : '/eu/pribatutasuna';
---

<!-- Banner -->
<div
  id="cc-banner"
  class="cc-banner"
  role="dialog"
  aria-modal="false"
  aria-labelledby="cc-banner-title"
  hidden
>
  <div class="cc-banner-inner">
    <h2 id="cc-banner-title" class="cc-title">{t('cookies.banner.title')}</h2>
    <p class="cc-text">
      {t('cookies.banner.text')}
      <a href={cookiesUrl}>{t('cookies.banner.link_cookies')}</a>
      ·
      <a href={privacyUrl}>{t('cookies.banner.link_privacy')}</a>
    </p>

    <div class="cc-actions">
      <button class="btn btn-secondary cc-btn-config" type="button" data-cc="config">
        {t('cookies.banner.btn_config')}
      </button>
      <button class="btn btn-secondary" type="button" data-cc="reject">
        {t('cookies.banner.btn_reject')}
      </button>
      <button class="btn btn-primary" type="button" data-cc="accept">
        {t('cookies.banner.btn_accept')}
      </button>
    </div>
  </div>
</div>

<!-- Panel de configuración -->
<div
  id="cc-panel"
  class="cc-panel"
  role="dialog"
  aria-modal="true"
  aria-labelledby="cc-panel-title"
  hidden
>
  <div class="cc-panel-inner">
    <h2 id="cc-panel-title" class="cc-title">{t('cookies.panel.title')}</h2>
    <p class="cc-text">{t('cookies.panel.intro')}</p>

    <ul class="cc-categories">
      <li>
        <label class="cc-cat">
          <input type="checkbox" checked disabled data-cc-cat="necessary">
          <div>
            <strong>{t('cookies.cats.necessary.name')}</strong>
            <span>{t('cookies.cats.necessary.desc')}</span>
          </div>
        </label>
      </li>
      <li>
        <label class="cc-cat">
          <input type="checkbox" data-cc-cat="maps">
          <div>
            <strong>{t('cookies.cats.maps.name')}</strong>
            <span>{t('cookies.cats.maps.desc')}</span>
          </div>
        </label>
      </li>
      <li>
        <label class="cc-cat">
          <input type="checkbox" data-cc-cat="analytics">
          <div>
            <strong>{t('cookies.cats.analytics.name')}</strong>
            <span>{t('cookies.cats.analytics.desc')}</span>
          </div>
        </label>
      </li>
      <li>
        <label class="cc-cat">
          <input type="checkbox" data-cc-cat="marketing">
          <div>
            <strong>{t('cookies.cats.marketing.name')}</strong>
            <span>{t('cookies.cats.marketing.desc')}</span>
          </div>
        </label>
      </li>
    </ul>

    <div class="cc-actions">
      <button class="btn btn-secondary" type="button" data-cc="reject">
        {t('cookies.banner.btn_reject')}
      </button>
      <button class="btn btn-secondary" type="button" data-cc="save">
        {t('cookies.panel.btn_save')}
      </button>
      <button class="btn btn-primary" type="button" data-cc="accept">
        {t('cookies.banner.btn_accept')}
      </button>
    </div>
  </div>
</div>

<!-- Botón flotante para reabrir preferencias -->
<button
  id="cc-reopen"
  class="cc-reopen"
  type="button"
  aria-label={t('cookies.reopen_aria')}
  title={t('cookies.reopen_aria')}
  data-cc="config"
  hidden
>
  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <circle cx="12" cy="12" r="10"/>
    <circle cx="9.5" cy="9.5" r="0.7" fill="currentColor"/>
    <circle cx="15" cy="11" r="0.7" fill="currentColor"/>
    <circle cx="11" cy="15" r="0.7" fill="currentColor"/>
    <circle cx="14.5" cy="15.5" r="0.7" fill="currentColor"/>
  </svg>
</button>

<style>
  .cc-banner[hidden],
  .cc-panel[hidden],
  .cc-reopen[hidden] {
    display: none !important;
  }

  .cc-banner {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 200;
    background: var(--bg-deep);
    border-top: 1px solid var(--copper);
    box-shadow: 0 -10px 40px rgba(0, 0, 0, 0.5);
    padding: 1.5rem var(--gutter) calc(1.5rem + 28px);
  }
  .cc-banner-inner {
    max-width: var(--container-max);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 1rem 2rem;
    align-items: center;
  }
  .cc-title {
    font-family: var(--font-display);
    font-size: 1.25rem;
    letter-spacing: 0.12em;
    color: var(--copper);
    grid-column: 1 / -1;
  }
  .cc-text {
    font-family: var(--font-serif);
    font-size: 0.95rem;
    color: var(--cream-soft);
    font-weight: 300;
    line-height: 1.55;
  }
  .cc-text a {
    color: var(--copper-bright);
    border-bottom: 1px solid rgba(224, 138, 69, 0.4);
  }
  .cc-text a:hover {
    border-bottom-color: var(--copper-bright);
  }

  .cc-actions {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    justify-content: flex-end;
  }
  .cc-actions .btn {
    padding: 0.7rem 1.2rem;
    font-size: 0.75rem;
    white-space: nowrap;
  }

  .cc-panel {
    position: fixed;
    inset: 0;
    z-index: 210;
    background: rgba(13, 11, 9, 0.85);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
    overflow-y: auto;
  }
  .cc-panel-inner {
    background: var(--bg-card);
    border: 1px solid var(--line-strong);
    max-width: 640px;
    width: 100%;
    padding: 2rem;
    border-radius: 4px;
    max-height: 90vh;
    overflow-y: auto;
  }
  .cc-panel .cc-title { margin-bottom: 0.75rem; }
  .cc-panel .cc-text { margin-bottom: 1.5rem; }

  .cc-categories {
    list-style: none;
    padding: 0;
    margin: 0 0 1.5rem;
    border-top: 1px solid var(--line);
  }
  .cc-categories li {
    border-bottom: 1px solid var(--line);
  }
  .cc-cat {
    display: flex;
    gap: 1rem;
    padding: 1rem 0;
    align-items: flex-start;
    cursor: pointer;
  }
  .cc-cat input {
    width: 18px;
    height: 18px;
    margin-top: 4px;
    accent-color: var(--copper);
    cursor: pointer;
    flex-shrink: 0;
  }
  .cc-cat input:disabled { cursor: not-allowed; }
  .cc-cat strong {
    display: block;
    font-family: var(--font-body);
    font-size: 0.85rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--cream);
    margin-bottom: 0.25rem;
  }
  .cc-cat span {
    font-family: var(--font-serif);
    font-size: 0.95rem;
    color: var(--cream-soft);
    font-weight: 300;
    line-height: 1.5;
  }

  .cc-reopen {
    position: fixed;
    bottom: 84px;
    left: 24px;
    z-index: 90;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--bg-card);
    color: var(--copper);
    border: 1px solid var(--line-strong);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all var(--transition-fast);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.4);
  }
  .cc-reopen:hover {
    color: var(--copper-bright);
    border-color: var(--copper);
  }

  @media (max-width: 768px) {
    .cc-banner-inner {
      grid-template-columns: 1fr;
    }
    .cc-actions {
      justify-content: stretch;
    }
    .cc-actions .btn {
      flex: 1;
    }
    .cc-reopen {
      bottom: 76px;
      left: 16px;
    }
  }
</style>

<script>
  /**
   * Cookie consent — robusto frente a ViewTransitions.
   *  · Listener global delegado en document → sobrevive a swaps de DOM.
   *  · Estado se restaura en cada `astro:page-load` (porque el banner es parte
   *    del contenido swappeado).
   *  · Flag `__erreka_cc_init` evita doble-binding del listener global.
   */
  type Consent = {
    necessary: true;
    maps: boolean;
    analytics: boolean;
    marketing: boolean;
    ts: number;
    v: number;
  };

  const STORAGE_KEY = 'erreka_cookie_consent';
  const SCHEMA_VERSION = 1;
  const ONE_YEAR_MS = 365 * 24 * 60 * 60 * 1000;

  function read(): Consent | null {
    try {
      const raw = localStorage.getItem(STORAGE_KEY);
      if (!raw) return null;
      const parsed = JSON.parse(raw) as Consent;
      if (parsed.v !== SCHEMA_VERSION) return null;
      if (Date.now() - parsed.ts > ONE_YEAR_MS) return null;
      return parsed;
    } catch { return null; }
  }

  function write(c: Omit<Consent, 'ts' | 'v' | 'necessary'>) {
    const value: Consent = {
      necessary: true,
      maps: !!c.maps,
      analytics: !!c.analytics,
      marketing: !!c.marketing,
      ts: Date.now(),
      v: SCHEMA_VERSION,
    };
    localStorage.setItem(STORAGE_KEY, JSON.stringify(value));
    window.dispatchEvent(new CustomEvent('cookie-consent:change', { detail: value }));
    return value;
  }

  function clear() {
    localStorage.removeItem(STORAGE_KEY);
  }

  // Lookup fresco en cada acción — nunca cachear referencias del DOM porque
  // ViewTransitions las invalida al navegar.
  const $ = (id: string) => document.getElementById(id);

  function showBanner() { $('cc-banner')?.removeAttribute('hidden'); }
  function hideBanner() { $('cc-banner')?.setAttribute('hidden', ''); }
  function showPanel(consent: Consent | null) {
    const panel = $('cc-panel');
    if (!panel) return;
    panel.removeAttribute('hidden');
    document.body.style.overflow = 'hidden';
    const c = consent ?? { maps: false, analytics: false, marketing: false };
    panel.querySelectorAll<HTMLInputElement>('[data-cc-cat]').forEach(input => {
      const cat = input.dataset.ccCat as keyof typeof c;
      if (cat !== 'necessary' as any) input.checked = !!(c as any)[cat];
    });
  }
  function hidePanel() {
    $('cc-panel')?.setAttribute('hidden', '');
    document.body.style.overflow = '';
  }
  function showReopen() { $('cc-reopen')?.removeAttribute('hidden'); }
  function hideReopen() { $('cc-reopen')?.setAttribute('hidden', ''); }

  function applyConsent(c: Consent) {
    hideBanner();
    hidePanel();
    showReopen();
  }

  function handleAction(action: string) {
    switch (action) {
      case 'accept': {
        const v = write({ maps: true, analytics: true, marketing: true });
        applyConsent(v);
        break;
      }
      case 'reject': {
        const v = write({ maps: false, analytics: false, marketing: false });
        applyConsent(v);
        break;
      }
      case 'config': {
        showPanel(read());
        break;
      }
      case 'save': {
        const get = (cat: string) =>
          ($('cc-panel')?.querySelector<HTMLInputElement>(`[data-cc-cat="${cat}"]`)?.checked) ?? false;
        const v = write({
          maps: get('maps'),
          analytics: get('analytics'),
          marketing: get('marketing'),
        });
        applyConsent(v);
        break;
      }
    }
  }

  /** Restaura el estado visible del banner/reopen según localStorage.
   *  Se llama al cargar la página y tras cada View Transition. */
  function restoreState() {
    const stored = read();
    if (stored) {
      hideBanner();
      hidePanel();
      showReopen();
      window.dispatchEvent(new CustomEvent('cookie-consent:change', { detail: stored }));
    } else {
      hideReopen();
      hidePanel();
      showBanner();
    }
  }

  // Listeners GLOBALES — solo se registran una vez por sesión.
  if (!(window as any).__erreka_cc_init) {
    (window as any).__erreka_cc_init = true;

    // Delegation: cualquier click en un elemento con [data-cc="<action>"].
    document.addEventListener('click', (e) => {
      const target = e.target instanceof Element ? e.target.closest('[data-cc]') : null;
      if (!target) return;
      const action = (target as HTMLElement).dataset.cc;
      if (action) handleAction(action);
    });

    // Evento público: que el footer u otros sitios puedan abrir el panel.
    window.addEventListener('cookie-consent:open', () => showPanel(read()));

    // Helper público en window para depuración.
    (window as any).errekaCookieConsent = { read, clear, write };
  }

  // Restaurar estado inicial Y en cada View Transition.
  restoreState();
  document.addEventListener('astro:page-load', restoreState);
</script>
