---
import { restaurant } from '@content/restaurant';
import type { Lang } from '@i18n/index';

interface Props {
  lang?: Lang;
}

const { lang = 'es' } = Astro.props;

// Mensaje pre-rellenado según idioma. Mejora la conversión: el cliente
// abre WhatsApp y ya tiene un saludo listo en su idioma.
const messages = {
  es: 'Hola, me gustaría hacer una reserva en Erreka Meet Point.',
  eu: 'Kaixo, mahaia erreserbatu nahi dut Erreka Meet Pointen.',
};
const text = encodeURIComponent(messages[lang]);
const href = `https://wa.me/${restaurant.whatsapp}?text=${text}`;

const aria = lang === 'eu' ? 'WhatsApp bidez idatzi' : 'Escríbenos por WhatsApp';
---

<a
  href={href}
  class="whatsapp-float"
  aria-label={aria}
  target="_blank"
  rel="noopener"
>
  <svg viewBox="0 0 24 24" aria-hidden="true">
    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
  </svg>
  <span class="ripple" aria-hidden="true"></span>
</a>

<style>
  .whatsapp-float {
    position: fixed;
    bottom: 4.5rem;
    right: 1.5rem;
    width: 56px;
    height: 56px;
    background: var(--whatsapp);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 90;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.4);
    transition: transform 0.25s var(--ease-out-soft), box-shadow 0.25s ease;
    overflow: hidden;
  }
  .whatsapp-float:hover {
    transform: scale(1.08);
    box-shadow: 0 12px 32px rgba(37, 211, 102, 0.45);
  }
  .whatsapp-float svg {
    width: 28px;
    height: 28px;
    fill: white;
    position: relative;
    z-index: 2;
  }
  /* Ripple sutil para invitar a click — desactivable con reduced-motion */
  .ripple {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    border: 2px solid rgba(255, 255, 255, 0.4);
    animation: ripple 2.6s ease-out infinite;
  }
  @keyframes ripple {
    0%   { transform: scale(0.95); opacity: 0.5; }
    100% { transform: scale(1.6); opacity: 0; }
  }
  @media (prefers-reduced-motion: reduce) {
    .ripple { animation: none; opacity: 0; }
  }
</style>
