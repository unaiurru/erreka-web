---
/**
 * Página "Quiénes somos / Gu nor garen".
 * Componente único para ES/EU. Lee values del JSON correspondiente.
 *
 * Mejoras vs. versión anterior:
 *  · Sustituye el hack `direction: rtl` por `grid-template-areas` + .reverse
 *    (a11y-friendly, no rompe inputs ni lectores de pantalla).
 *  · Pull-quote en cursiva grande entre bloques.
 *  · Numerales gigantes 01·02·03 detrás del texto en values.
 *  · Reveal-on-scroll en cada bloque.
 */
import { useTranslations, type Lang } from '@i18n/index';
import esJson from '@i18n/es.json';
import euJson from '@i18n/eu.json';
import Icon from '@components/Icon.astro';
import SectionDivider from '@components/SectionDivider.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const valuesData = (lang === 'eu' ? euJson : esJson).about_page.values;

const reserveHref = lang === 'eu' ? '/eu/erreserbak' : '/es/reservas';
const menuHref = lang === 'eu' ? '/eu/karta' : '/es/carta';

// Cita destacada — la sacamos de la sección 2 (cocina) y la tratamos como tal.
const pullQuote = lang === 'eu'
  ? 'Gauza gutxi egin nahiago, baina ondo eginda.'
  : 'Preferimos hacer pocas cosas, pero hacerlas bien.';
---

<!-- HERO -->
<section class="about-hero">
  <div class="about-hero-bg img-slot" data-slot="HERO · Foto del equipo o vista general del local"></div>
  <div class="about-hero-content container">
    <div class="section-label" data-reveal>{t('about_page.label')}</div>
    <h1 class="section-title big" data-reveal data-reveal-delay="1">
      {t('about_page.title_line1')}<br>
      <span class="accent">{t('about_page.title_line2')}</span>
    </h1>
    <p class="about-intro" data-reveal data-reveal-delay="2">{t('about_page.intro')}</p>
  </div>
</section>

<!-- HISTORIA EN BLOQUES -->
<section class="story container">
  <div class="story-block" data-reveal>
    <div class="story-img img-slot" data-slot="Foto · Local de día / barra"></div>
    <div class="story-text">
      <h2>{t('about_page.section1_title')}</h2>
      <p>{t('about_page.section1_p1')}</p>
      <p>{t('about_page.section1_p2')}</p>
    </div>
  </div>

  <!-- Pull-quote: cita destacada que rompe el ritmo -->
  <blockquote class="pull-quote" data-reveal>
    <span class="quote-mark" aria-hidden="true">"</span>
    <p>{pullQuote}</p>
  </blockquote>

  <div class="story-block reverse" data-reveal>
    <div class="story-img img-slot" data-slot="Foto · Plato emblemático / cocina en acción"></div>
    <div class="story-text">
      <h2>{t('about_page.section2_title')}</h2>
      <p>{t('about_page.section2_p1')}</p>
      <p>{t('about_page.section2_p2')}</p>
    </div>
  </div>

  <div class="story-block" data-reveal>
    <div class="story-img img-slot" data-slot="Foto · Equipo trabajando o atendiendo"></div>
    <div class="story-text">
      <h2>{t('about_page.section3_title')}</h2>
      <p>{t('about_page.section3_p1')}</p>
    </div>
  </div>
</section>

<SectionDivider variant="brush" />

<!-- VALORES -->
<section class="values-section container">
  <h2 class="section-title" data-reveal>{t('about_page.values_title')}</h2>
  <div class="values-grid">
    {valuesData.map((v, i) => (
      <div class="value-card" data-reveal data-reveal-delay={Math.min(i + 1, 5).toString()}>
        <span class="value-number" aria-hidden="true">0{i + 1}</span>
        <h3>{v.title}</h3>
        <p>{v.desc}</p>
      </div>
    ))}
  </div>
</section>

<!-- CTA FINAL -->
<section class="about-cta">
  <div class="container-narrow">
    <h2 class="section-title" data-reveal>{t('about_page.cta_title')}</h2>
    <p class="cta-desc" data-reveal data-reveal-delay="1">{t('about_page.cta_desc')}</p>
    <div class="cta-actions" data-reveal data-reveal-delay="2">
      <a href={reserveHref} class="btn btn-primary btn-magnetic" data-magnetic>
        {t('about_page.cta_reserve')}
      </a>
      <a href={menuHref} class="btn btn-secondary btn-with-icon">
        {t('about_page.cta_menu')}
        <Icon name="arrow-right" size={16} />
      </a>
    </div>
  </div>
</section>

<style>
  /* Hero */
  .about-hero {
    position: relative;
    min-height: 60vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    padding: 6rem 0 4rem;
  }
  .about-hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .about-hero-bg::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(22, 19, 16, 0.75) 0%, rgba(22, 19, 16, 0.95) 100%);
  }
  .about-hero-content { position: relative; z-index: 2; }
  .section-title.big {
    font-size: clamp(3rem, 9vw, 6.5rem);
  }
  .section-title .accent { color: var(--copper); }
  .about-intro {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: clamp(1.2rem, 2vw, 1.5rem);
    color: var(--cream-soft);
    max-width: 700px;
    line-height: 1.6;
    margin-top: 1rem;
  }

  /* Historia */
  .story {
    padding: 5rem var(--gutter);
    display: flex;
    flex-direction: column;
    gap: 5rem;
  }
  .story-block {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
    grid-template-areas: "img text";
  }
  .story-block .story-img { grid-area: img; }
  .story-block .story-text { grid-area: text; }
  /* Reverse via grid-template-areas, no `direction: rtl` */
  .story-block.reverse {
    grid-template-areas: "text img";
  }
  .story-img {
    aspect-ratio: 4/3;
    border-radius: 2px;
  }
  .story-text h2 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 2.75rem);
    color: var(--copper);
    margin-bottom: 1.5rem;
    letter-spacing: 0.05em;
  }
  .story-text p {
    font-family: var(--font-serif);
    font-size: 1.1rem;
    color: var(--cream-soft);
    line-height: 1.8;
    margin-bottom: 1rem;
    font-weight: 300;
  }

  /* Pull-quote */
  .pull-quote {
    position: relative;
    text-align: center;
    max-width: 720px;
    margin: 0 auto;
    padding: 1.5rem 1rem;
  }
  .pull-quote .quote-mark {
    position: absolute;
    top: -2.5rem;
    left: 50%;
    transform: translateX(-50%);
    font-family: var(--font-serif);
    font-size: 6rem;
    line-height: 1;
    color: var(--copper);
    opacity: 0.35;
  }
  .pull-quote p {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    line-height: 1.4;
    color: var(--cream);
    font-weight: 300;
  }

  /* Valores con numerales gigantes detrás */
  .values-section {
    padding: 5rem var(--gutter);
  }
  .values-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 2rem;
    margin-top: 3rem;
  }
  .value-card {
    padding: 2.5rem 1.5rem 2rem;
    background: var(--bg-card);
    border: 1px solid var(--line);
    position: relative;
    overflow: hidden;
    transition: transform 0.35s var(--ease-out-soft), border-color 0.3s ease, box-shadow 0.3s ease;
  }
  .value-card:hover {
    border-color: var(--copper);
    transform: translateY(-6px);
    box-shadow: 0 20px 40px -20px rgba(0, 0, 0, 0.6);
  }
  /* Numeral gigante: ahora es un ornamento detrás (más editorial) */
  .value-number {
    position: absolute;
    top: -0.5rem;
    right: 0.75rem;
    font-family: var(--font-display);
    font-size: 5.5rem;
    line-height: 1;
    color: var(--copper);
    opacity: 0.12;
    letter-spacing: 0.05em;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }
  .value-card:hover .value-number {
    opacity: 0.22;
  }
  .value-card h3 {
    font-family: var(--font-display);
    font-size: 1.5rem;
    letter-spacing: 0.1em;
    color: var(--cream);
    margin: 0 0 0.75rem;
    position: relative;
    z-index: 1;
  }
  .value-card p {
    font-family: var(--font-serif);
    font-size: 1rem;
    color: var(--cream-soft);
    line-height: 1.6;
    font-weight: 300;
    font-style: italic;
    position: relative;
    z-index: 1;
  }

  /* CTA final */
  .about-cta {
    padding: 6rem var(--gutter);
    text-align: center;
    background: linear-gradient(180deg, var(--bg) 0%, var(--bg-soft) 100%);
    border-top: 1px solid var(--line);
  }
  .cta-desc {
    font-family: var(--font-serif);
    font-size: 1.2rem;
    color: var(--cream-soft);
    margin-bottom: 2.5rem;
    font-weight: 300;
    font-style: italic;
  }
  .cta-actions {
    display: flex;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .btn-with-icon {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
  }

  @media (max-width: 768px) {
    .story { padding: 3rem 1.25rem; gap: 3rem; }
    .story-block,
    .story-block.reverse {
      grid-template-columns: 1fr;
      grid-template-areas: "img" "text";
      gap: 1.5rem;
    }
    .values-section, .about-cta { padding: 3rem 1.25rem; }
    .pull-quote .quote-mark { font-size: 4rem; top: -1.75rem; }
  }
</style>
